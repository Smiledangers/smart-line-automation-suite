# Environment variables for demo_project
# Copy this to .env and fill in the values

# Application
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
PROJECT_NAME=Smart LINE Bot + Dashboard + Scraper Pipeline
API_V1_STR=/api/v1

# Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=demo_project
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/demo_project

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_REDIRECT_URI=http://localhost:8000/api/v1/line/callback

# AI / LLM
OPENAI_API_KEY=your-openai-api-key
# For local models, you might set:
# LOCAL_LLM_MODEL_PATH=/path/to/model
# LOCAL_LLM_TYPE=llama

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=60 * 24 * 7  # 7 days
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Scraping
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
REQUEST_DELAY=1  # seconds between requests
MAX_RETRIES=3

# Monitoring
SENTRY_DNS=
PROMETHEUS_PORT=9090

# Email (for notifications)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=your-email@gmail.com

# Superuser
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis